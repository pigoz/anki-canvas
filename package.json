{
  "name": "anki-canvas",
  "version": "0.0.1",
  "description": "JavaScript widget providing touch enabled canvas for drawing in AnkiDroid",
  "main": "index.js",
  "repository": "https://github.com/pigoz/anki-canvas",
  "author": "pigoz",
  "license": "MIT",
  "dependencies": {
    "@types/hyperscript": "^0.0.3",
    "hyperscript": "^2.0.2"
  },
  "devDependencies": {
    "@types/chalk": "^2.2.4",
    "@types/node": "^22.15.21",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "@vitejs/plugin-legacy": "^6.1.1",
    "@vitest/coverage-c8": "^0.33.0",
    "chalk": "^3.0.0",
    "dprint": "^0.50.0",
    "eslint": "^9.27.0",
    "eslint-config-standard-with-typescript": "^43.0.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-n": "^17.18.0",
    "eslint-plugin-promise": "^7.2.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.4"
  },
  "scripts": {
    "test": "bun run vitest",
    "lint": "eslint . --ext .ts,.js",
    "format": "dprint fmt",
    "format:check": "dprint check",
    "start": "bun run vite dev",
    "build": "bun run vite build",
    "dist": "bun run vite build && bun run scripts/dist.ts",
    "release": "rm -r dist && bun run vite build && cd scripts && ./release.py"
  }
}
